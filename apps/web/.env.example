# Chronos-Sentinel — Next.js UI Environment Template
# Copy this file to '.env.local' for local development.

# Shared Database Connections (Same as Root)
MONGO_URI=mongodb+srv://user:password@cluster.8ef5wvm.mongodb.net/chronos-sentinel?retryWrites=true&w=majority
REDIS_URL=redis://default:your-password@your-redis-host:18550
RABBITMQ_URL=amqps://user:password@lionfish.rmq.cloudamqp.com/vhost

# NextAuth Configuration
# For production, change this to your Vercel URL
NEXTAUTH_URL=http://localhost:3000
# Generate a secure 32-character secret using: openssl rand -base64 32
NEXTAUTH_SECRET=chronos-sentinel-dev-secret-replace-me
